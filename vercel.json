{
  "redirects": [
    {
      "source": "/soccer/league/(.*)",
      "destination": "/leagues",
      "permanent": true
    },
    {
      "source": "/league/(.*)",
      "destination": "/leagues",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}